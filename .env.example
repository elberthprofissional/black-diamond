# =============================================================================
# BLACK DIAMOND — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env ou .env.local!
# =============================================================================

# ─── Supabase (OBRIGATÓRIO) ───
# URL do seu projeto Supabase + chave anônima (pública, pode ficar no frontend)
# Substitua pelos valores do SEU projeto Supabase.
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# ─── Push Notifications (VAPID) ───
# Gere as chaves em: https://web-push-codelab.glitch.me/
# A chave PÚBLICA vai no .env (frontend).
# A chave PRIVADA vai como secret no Supabase (backend).
# Comando para setar a secret no Supabase:
#   supabase secrets set VAPID_PRIVATE_KEY=sua_chave_privada_aqui
#   supabase secrets set VAPID_PUBLIC_KEY=sua_chave_publica_aqui
# Substitua pela chave PÚBLICA gerada no link acima.
VITE_VAPID_PUBLIC_KEY=sua_chave_vapid_publica_aqui

# ─── Sentry (Monitoramento de Erros — OPCIONAL) ───
# Crie uma conta em: https://sentry.io/
# Crie um projeto React e copie o DSN aqui.
VITE_SENTRY_DSN=

# ─── Google Analytics (Opcional) ───
# Crie uma propriedade em: https://analytics.google.com/
VITE_GA_ID=

# ─── URL do Site (para templates de WhatsApp) ───
VITE_SITE_URL=https://black-diamond.vercel.app

# ─── Google Reviews (Edge Function Secrets) ───
# Após deploy da edge function sync-google-reviews, execute:
#   supabase secrets set GOOGLE_PLACES_API_KEY=sua_chave_api
#   supabase secrets set GOOGLE_PLACE_ID=seu_place_id
#
# Como conseguir:
# - API Key: https://console.cloud.google.com (grátis, $200/mês de crédito)
# - Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id

# ─── WhatsApp do Barbeiro (para templates) ───
VITE_BARBER_WHATSAPP=
